# RewindX - Environment Variables
# Copy this file to .env and fill in your values

# Ollama Configuration
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_VISION_MODEL=qwen2.5vl:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TEXT_MODEL=qwen2.5-coder:3b
OLLAMA_CODER_MODEL=qwen2.5-coder:3b

# Qdrant Vector Database Configuration
# For local Qdrant: http://localhost:6333
# For Qdrant Cloud: https://your-instance-url:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=aiworkmemory
